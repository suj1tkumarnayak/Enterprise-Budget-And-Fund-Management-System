# ── Application ──────────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000

# ── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://ebfms_dev:changeme@localhost:5432/ebfms_dev"

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET="replace-with-64-byte-random-hex"
JWT_REFRESH_SECRET="replace-with-64-byte-random-hex"
JWT_ACCESS_EXPIRY="15m"
JWT_REFRESH_EXPIRY="7d"

# ── CORS ──────────────────────────────────────────────────────────────────────
CORS_ALLOWED_ORIGINS="http://localhost:5173"

# ── Cloudinary (file uploads) ─────────────────────────────────────────────────
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Nodemailer / SMTP ─────────────────────────────────────────────────────────
SMTP_HOST="smtp.sendgrid.net"
SMTP_PORT=587
SMTP_USER="apikey"
SMTP_PASS=""
SMTP_FROM="noreply@ebfms.example.com"

# ── Redis (optional) ──────────────────────────────────────────────────────────
REDIS_URL="redis://localhost:6379"

# ── Seed (used by prisma/seed.ts only — never read at runtime) ────────────────
# The Admin user is forced to change this password on first login.
SEED_ADMIN_EMAIL="admin@ebfms.io"
SEED_ADMIN_PASSWORD="ChangeMe@12345!"
